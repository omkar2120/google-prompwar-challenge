# ─────────────────────────────────────────────────────────────
# MonsoonMitra environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# GroqCloud API key — powers every AI feature (plans, chatbot, alerts, etc.)
# Get one free at https://console.groq.com/keys
VITE_GROQ_API_KEY=

# OPTIONAL: If you deploy the serverless proxy in `api/groq.js` (recommended for
# production so the key never ships to the browser), set this to the proxy path
# (e.g. /api/groq) and set GROQ_API_KEY in the server env instead of the key above.
VITE_GROQ_PROXY_URL=

# ── Firebase (Community Hazard Map — optional) ──
# If these are left blank, the app automatically falls back to a clearly-labeled
# "local-only" mode where community reports are visible only on this device.
# Create a free Spark-tier project at https://console.firebase.google.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
